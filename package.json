{
  "name": "tracepilot-testability-checker",
  "version": "0.1.0",
  "private": true,
  "description": "TracePilot QA lead magnet that checks whether user stories are testable before regression automation begins.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "preview": "vite preview --host 127.0.0.1",
    "serve:static": "node scripts/dev-server.mjs",
    "build": "node scripts/verify.mjs && vite build",
    "samples": "node scripts/check-samples.mjs",
    "test": "node --test src/analyzer.test.mjs"
  },
  "keywords": [
    "tracepilot",
    "qa",
    "playwright",
    "testability",
    "user-stories"
  ],
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "vite": "7.3.5"
  },
  "overrides": {
    "esbuild": "0.28.1"
  }
}
